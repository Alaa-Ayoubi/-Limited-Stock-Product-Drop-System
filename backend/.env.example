# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/limited_drop_db"

# Server
PORT=3001
NODE_ENV=development

# JWT (generate a strong secret: openssl rand -hex 64)
JWT_SECRET=your-super-secret-key-minimum-32-characters-long
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Reservation TTL in minutes
RESERVATION_TTL_MINUTES=5
